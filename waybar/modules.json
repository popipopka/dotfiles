{
	"bluetooth": {
		"on-click": "kitty -e bluetuith",
		"on-click-right": "~/.config/waybar/scripts/bluetooth-control",
		
		"format-on": "<span>≤░Γψ</span>",
		"format-off": "≤░Γ▓",
		"format-disabled": "≤░Γ▓",
		
		"format-connected": "≤░Γ▒",
		"format-connected-battery": "≤░Γ▒ {device_battery_percentage}%",
		
		"tooltip-format": "",
		"tooltip-format-connected": "{device_alias}",
		"tooltip-format-connected-battery": "{device_alias}\t{device_battery_percentage}%",
		
		"tooltip-format-enumerate-connected": "{device_alias}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_battery_percentage}%"
	},
    "pulseaudio": {
		"tooltip": false,
        
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 2 @DEFAULT_AUDIO_SINK@ 5%-",
        "on-scroll-down": "wpctl set-volume -l 2 @DEFAULT_AUDIO_SINK@ 5%+",
        "scroll-step": 5,
        
		"format": "{icon} {volume}%",
        "format-muted": "ΎΣο Muted",
        "format-icons": {
            "headphone": "ΎΑξ ",
            "hands-free": "ΎΑξ ",
            "headset": "ΎΑξ ",
            "phone": "ΎΓΧ ",
            "portable": "ΎΓΧ ",
            "car": "ΎΗ╣ ",
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
        },
        
        "min-length": 8
    },
    "network": {
        "interval": 5,
        
        "format": "{ifname}",
        "format-wifi": "{icon} {essid} ({signalStrength}%)",
        "format-ethernet": "Ethernet {ipaddr}/{cidr}",
        "format-disconnected": "Disconnected",
        
        "format-icons": [
        	"≤░λ┐ ",
        	"≤░λ╝ ",
        	"≤░λ╜ ",
        	"≤░λ╛ ",
        ],
        
        "tooltip-format": "{ifname} via {gwaddr}",
        "tooltip-format-wifi": "Wi-Fi  {essid}",
        "tooltip-format-ethernet": "Ethernet  {ifname}",
        "tooltip-format-disconnected": "Disconnected",
        
        "max-length": 50,
        "min-length": 8,
        
        "on-click": "kitty -e nmtui"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    "clock": {
        "format": "<span>{:%a, %e %b   %R}</span>",
        "timezone": "Europe/Moscow",
        "tooltip": "false",
    },
    "battery": {
        "interval": 10,
        
        "states": {
            "warning": 40,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": [
				"ΎΚΕ ", 
				"ΎΚΔ ", 
				"ΎΚΓ ", 
				"ΎΚΒ ", 
				"ΎΚΑ "
        ],
        
        "min-length": 8
    },
    "backlight": {
        "device": "intel_backlight",
        
        "format": "{icon} {percent}%",
        "format-icons": [
            "≤░Δη ",
            "ΌΟρ ",
            "ΌΟο ",
            "ΌΟν ",
            "≤░Δθ ",
            "ΌΟι ",
            "ΌΟη ",
            "ΌΟε ",
            "≤░Δι "
        ],
        
        "on-scroll-up": "brightnessctl set 7%-",
        "on-scroll-down": "brightnessctl set 7%+",
        
        "min-length": 8
    },
}
